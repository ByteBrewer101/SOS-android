# ═══════════════════════════════════════════════════════════════════════════════
#  SOS Backend — VPS Production Environment
#  Copy this file to .env on your VPS and fill in every value.
#  NEVER commit this file with real secrets to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# These become the root credentials for the Mongo container.
# Pick strong values — the DB is only on the internal Docker network,
# but auth is still required.
MONGO_ROOT_USER=sos_admin
MONGO_ROOT_PASSWORD=CHANGE_ME_strong_password_here
MONGO_DB_NAME=sos_app

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_64_byte_hex_string
JWT_EXPIRES_IN=30d

# ─── Aadhaar Encryption ───────────────────────────────────────────────────────
# MUST be exactly 32 characters (AES-256-CBC key)
AADHAAR_ENCRYPTION_KEY=CHANGE_ME_exactly_32_chars_here!

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to your mobile app's backend URL or the Nginx/Caddy domain.
# Use * only for testing; tighten for production.
CORS_ORIGIN=*

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── SMS (optional — leave blank to keep stubbed) ─────────────────────────────
SMS_API_KEY=
SMS_SENDER_ID=SOSAPP

# ─── Firebase FCM (optional — leave blank to keep stubbed) ───────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
