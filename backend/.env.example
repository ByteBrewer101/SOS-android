# ═══════════════════════════════════════════════════════════════════════════════
#  SOS Backend — Environment Variables
#  Copy this file to .env and fill in every value marked CHANGE_ME.
#  NEVER commit your real .env to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# These become the root credentials for the Mongo container.
# docker-compose builds the full connection string from these automatically.
MONGO_ROOT_USER=sos_admin
MONGO_ROOT_PASSWORD=CHANGE_ME_strong_password_here
MONGO_DB_NAME=sos_app

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_64_byte_hex_string
JWT_EXPIRES_IN=30d

# ─── Aadhaar Encryption ───────────────────────────────────────────────────────
# MUST be exactly 32 characters (AES-256-CBC key)
AADHAAR_ENCRYPTION_KEY=CHANGE_ME_exactly_32_chars_here!

# ─── SMTP (Email OTP via Nodemailer) ──────────────────────────────────────────
# Required for sending OTP emails.
# If using Gmail: create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Use * for testing; restrict to your domain in production.
CORS_ORIGIN=*

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Host Port (optional) ────────────────────────────────────────────────────
# Change if port 5000 is already in use on your machine.
API_PORT=5000

# ─── SMS (optional — leave blank to keep stubbed) ─────────────────────────────
SMS_API_KEY=
SMS_SENDER_ID=SOSAPP

# ─── Firebase FCM (optional — leave blank to keep stubbed) ───────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
