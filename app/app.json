{
  "expo": {
    "name": "SOS Emergency Alert",
    "slug": "sos-emergency-alert",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sos.emergency",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to send it with your SOS alert so emergency contacts and volunteers can find you.",
        "NSLocationAlwaysUsageDescription": "We need your location to send it with your SOS alert."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.sos.emergency",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CALL_PHONE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "a457fc9c-f30e-4a19-b03a-51f94ca8987f"
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow SOS Emergency to access your location for sending your position in SOS alerts."
        }
      ]
    ]
  }
}